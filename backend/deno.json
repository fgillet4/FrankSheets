{
  "tasks": {
    "dev": "deno run --allow-all --watch src/server.ts",
    "start": "deno run --allow-all src/server.ts",
    "test": "deno test --allow-all",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "imports": {
    "oak": "https://deno.land/x/oak@v12.6.1/mod.ts",
    "redis": "https://deno.land/x/redis@v0.31.0/mod.ts",
    "postgres": "https://deno.land/x/postgres@v0.17.0/mod.ts",
    "bcrypt": "https://deno.land/x/bcrypt@v0.4.1/mod.ts",
    "jwt": "https://deno.land/x/djwt@v2.8/mod.ts",
    "aws-sdk": "https://deno.land/x/aws_sdk@v3.4.1/mod.ts"
  }
}
